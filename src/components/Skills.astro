---
// ============================================================
// Skills — 기술 스택 섹션
// ============================================================
// src/data/skills.ts의 skillGroups를 카테고리별 카드로 펼칩니다.
// 카드 1개 = 카테고리 1개(언어/프론트/백엔드...), 안의 칩 = 기술 하나.
// 그리드: 모바일 1열 → sm 2열 → lg 3열 (반응형).

import Section from "./Section.astro"; // 공통 섹션 틀
import { t, type Lang } from "../i18n/ui"; // 제목 문구 조회
import { skillGroups } from "../data/skills"; // 기술 스택 데이터

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<!-- alt: 배경을 살짝 어둡게 해서 앞뒤 섹션과 시각적으로 구분 -->
<Section id="skills" eyebrow={t(lang, "section.skills.eyebrow")} title={t(lang, "section.skills.title")} alt>
  <!-- grid + gap-6: 카드 사이 간격 / sm:grid-cols-2 lg:grid-cols-3: 화면 폭에 따라 열 수 증가 -->
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      /* 카테고리(그룹) 하나당 카드 하나 생성 */
      skillGroups.map((group) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          {/* 카테고리 이름 — 대문자·자간 넓힘으로 "라벨" 스타일 */}
          <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
            {group.category[lang]}
          </h3>
          {/* flex-wrap: 칩이 많으면 자동 줄바꿈 */}
          <ul class="mt-4 flex flex-wrap gap-2">
            {/* 기술 하나당 민트 칩 하나 */}
            {group.items.map((item) => (
              <li class="rounded-lg bg-mint-50 px-3 py-1.5 text-sm font-medium text-mint-800 dark:bg-mint-400/10 dark:text-mint-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
