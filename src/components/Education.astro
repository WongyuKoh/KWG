---
// ============================================================
// Education — 학력 섹션
// ============================================================
// src/data/education.ts 배열을 카드 목록으로 나열합니다.

import Section from "./Section.astro"; // 공통 섹션 틀
import { t, type Lang } from "../i18n/ui"; // 제목 문구 조회
import { education } from "../data/education"; // 학력 데이터

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Section id="education" eyebrow={t(lang, "section.education.eyebrow")} title={t(lang, "section.education.title")} alt>
  <!-- space-y-4: 카드들 사이 세로 간격 (학력은 보통 1~2개라 그리드 대신 세로 나열) -->
  <div class="space-y-4">
    {
      /* 학력 하나당 카드 하나. 학교 정보(왼쪽)와 기간(오른쪽)을 양 끝 배치 */
      education.map((e) => (
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          <div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">{e.school[lang]}</h3>
            {/* 전공·학위 — 선택 필드(degree?)라서 "값 && 태그" 패턴으로 있을 때만 렌더링 */}
			{e.degree && <p class="mt-0.5 text-slate-600 dark:text-slate-300">{e.degree[lang]}</p>}

            {/* 부가 설명 — 역시 선택 필드. 없으면 <p> 자체가 생기지 않아 빈 줄도 안 남음 */}
			{e.desc && <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
				<p class="text-lg font-bold text-slate-900 dark:text-white">{"활동"}</p>
				{
					e.desc[lang].map((e1) => (
						<p>- {e1}</p>
					))
				}
			</p>}
          </div>
          <span class="text-sm font-medium text-slate-500 dark:text-slate-400">{e.period}</span>
        </div>
      ))
    }
  </div>
</Section>
