---
// ============================================================
// Hero — 첫 화면 (사이트의 얼굴)
// ============================================================
// 로고 마크 → 직무 → 이름 → 한 줄 소개 → 위치 → CTA 버튼 순서.
// 모든 텍스트는 src/data/profile.ts에서 오므로 여기선 배치만 담당합니다.
// CTA(Call To Action): 이력서 PDF 다운로드 / 연락처로 이동 / GitHub.

import Reveal from "./react/Reveal.tsx"; // 등장 애니메이션 래퍼
import KwgMark from "./KwgMark.astro"; // KWG 로고 이미지 컴포넌트
import { t, type Lang } from "../i18n/ui"; // 버튼 문구 조회
import { profile } from "../data/profile"; // 이름·직무·링크 등 데이터
import { withBase } from "../utils/url"; // public/ 파일 경로 보정

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<!--
  relative: 내부 absolute 장식들의 기준점
  overflow-hidden: 장식(빛 번짐)이 섹션 밖으로 삐져나가지 않게 자름
  pt-32: 위 여백 크게 — 고정 내비(4rem) 아래로 내용이 깔리지 않게 + 시원한 첫인상
-->
<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- 배경 장식: 위→아래 그라데이션 + 중앙 상단의 흐릿한 민트 빛 (-z-10로 내용 뒤에 깔림) -->
  <!-- pointer-events-none: 장식이 클릭을 가로채지 않도록 마우스 이벤트 통과 -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-mint-50 via-white to-white dark:from-slate-900 dark:via-slate-950 dark:to-slate-950"
  >
  </div>
  <!-- 민트 "빛": 둥근 원(h-72 w-72)에 blur-3xl로 강한 흐림 → 은은한 광원처럼 보임 -->
  <!-- left-1/2 -translate-x-1/2: 가로 중앙 정렬 상용구 (왼쪽 모서리를 50%로 보낸 뒤 자기 폭의 절반만큼 되돌림) -->
  <div
    class="pointer-events-none absolute -top-24 left-1/2 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-mint-400/25 blur-3xl dark:bg-mint-500/10"
  >
  </div>

  <div class="container-cv">
    <!-- client:load: 첫 화면이므로 보일 때까지 기다리지 않고 즉시 애니메이션 준비 -->
    <Reveal client:load>
      <!-- 세로 쌓기 + 가운데 정렬 + 텍스트 중앙 -->
      <div class="flex flex-col items-center text-center">
        <!-- 아바타: profile.photo가 비어 있으면(현재) KWG 로고 마크를 표시 -->
        {
          /* 삼항 조건부 렌더링: photo 값이 있으면 <img>, 없으면(빈 문자열="거짓") 로고 */
          profile.photo ? (
            <img
              src={withBase(profile.photo)}
              alt={profile.name[lang]}
              class="h-28 w-28 rounded-full object-cover shadow-lg ring-4 ring-white dark:ring-slate-800"
            />
          ) : (
            <KwgMark size={112} class="rounded-3xl shadow-lg ring-1 ring-slate-900/10 dark:ring-white/10" />
          )
        }

        <!-- 직무 라벨: uppercase 대문자화 + tracking-widest 자간 넓게 → "라벨" 느낌 -->
        <p class="mt-6 text-sm font-semibold uppercase tracking-widest text-mint-700 dark:text-mint-400">
          {profile.role[lang]}
        </p>
        <!-- 이름 = 페이지에서 가장 큰 글자(h1은 페이지당 1개가 SEO 관례) -->
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl dark:text-white">
          {profile.name[lang]}
        </h1>
        <!-- 한 줄 소개 -->
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          {profile.tagline[lang]}
        </p>
        <!-- 위치 -->
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">📍 {profile.location[lang]}</p>

        <!-- CTA 버튼 묶음. flex-wrap: 폭이 좁으면 다음 줄로 자연스럽게 줄바꿈 -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {
            /* resumePdf가 비어 있지 않을 때만 다운로드 버튼 표시 (&& 조건부 렌더링) */
            profile.resumePdf && (
              <a
                href={withBase(profile.resumePdf)}
                class="inline-flex items-center gap-2 rounded-full bg-mint-400 px-5 py-2.5 text-sm font-bold text-slate-950 shadow-sm transition hover:bg-mint-300"
                download
              >
                {/* download 속성: 링크를 열지 않고 "파일 저장" 동작을 유도 */}
                {/* 아래 SVG = 다운로드 아이콘 (쟁반 모양 + 아래 화살표를 선으로 그림) */}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" />
                </svg>
                {t(lang, "hero.cta.resume")}
              </a>
            )
          }
          <!-- 같은 페이지의 #contact 섹션으로 부드럽게 스크롤 -->
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
          >
            {t(lang, "hero.cta.contact")}
          </a>
          {
            /* github 필드({show, link} 객체)가 존재할 때만 원형 아이콘 버튼 표시.
               실제 이동 주소는 .link 쪽을 사용 (show는 Contact 카드의 표시용 텍스트) */
            profile.github && (
              <a
                href={profile.github.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-300 text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                aria-label="GitHub"
              >
                {/* target="_blank": 새 탭으로 열기 / rel="noopener noreferrer": 새 탭이
                    원본 탭을 조작하지 못하게 막는 보안 관례 (외부 링크엔 항상 세트로) */}
                {/* 아래 path 데이터 = GitHub 공식 문어(옥토캣) 실루엣 로고 좌표 */}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7 0-.7 0-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" />
                </svg>
              </a>
            )
          }
        </div>
      </div>
    </Reveal>
  </div>
</section>
