---
// ============================================================
// Achievements — 실적 · 수상 · 자격증 섹션
// ============================================================
// src/data/achievements.ts 배열을 2열 카드로 나열합니다.
// 카드: 제목 + 날짜(우측) → 발급기관(민트) → 한 줄 설명.

import Section from "./Section.astro"; // 공통 섹션 틀
import { t, type Lang } from "../i18n/ui"; // 제목 문구 조회
import { achievements } from "../data/achievements"; // 수상·자격 데이터

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Section id="achievements" eyebrow={t(lang, "section.achievements.eyebrow")} title={t(lang, "section.achievements.title")}>
  <!-- sm 이상에서 2열 -->
  <div class="grid gap-4 sm:grid-cols-2">
    {
      /* 항목 하나당 카드 하나 */
      achievements.map((a) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
          {/* 제목(왼쪽)과 날짜(오른쪽)를 양 끝으로. shrink-0: 제목이 길어도 날짜는 안 줄어듦 */}
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-bold text-slate-900 dark:text-white">{a.title[lang]}</h3>
            <span class="shrink-0 text-sm font-medium text-slate-500 dark:text-slate-400">{a.date}</span>
          </div>
          {/* 발급기관 — 브랜드 민트로 포인트 */}
          <p class="mt-1 text-sm font-medium text-mint-700 dark:text-mint-400">{a.issuer[lang]}</p>
          {/* 설명 */}
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{a.desc[lang]}</p>
        </div>
      ))
    }
  </div>
</Section>
