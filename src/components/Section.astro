---
// ============================================================
// Section — 모든 섹션이 공유하는 공통 틀
// ============================================================
// "아이브로우(작은 라벨) + 제목 + 내용(slot)" 구조를 통일해서
// 섹션마다 같은 여백·타이포·스크롤 애니메이션을 보장합니다.
// About, Skills, Experience 등이 전부 이 컴포넌트로 감쌉니다.

// 스크롤 진입 시 페이드인시키는 React 래퍼
import Reveal from "./react/Reveal.tsx";

interface Props {
  id: string; // 앵커 링크용 — Nav의 "#about" 등이 이 id로 스크롤됨
  eyebrow?: string; // 제목 위 작은 민트색 라벨 (예: "EXPERIENCE"). ?는 "생략 가능" 표시
  title: string; // 섹션 큰 제목
  alt?: boolean; // true면 배경을 살짝 어둡게 — 섹션끼리 줄무늬처럼 구분
}
// alt = false: 부모가 alt를 안 넘기면 기본값 false를 사용 (기본 배경)
const { id, eyebrow, title, alt = false } = Astro.props;
---

<!-- scroll-mt-16: 앵커로 점프할 때 고정 네비(높이 4rem)에 제목이 가려지지 않게 여백 확보 -->
<!--
  class:list — Astro의 조건부 클래스 문법. 배열 원소가:
    문자열이면 → 항상 적용
    "조건 && 클래스"면 → 조건이 참일 때만 적용 (거짓이면 무시됨)
-->
<section
  id={id}
  class:list={[
    "scroll-mt-16 py-20 sm:py-24",
    alt && "bg-slate-50 dark:bg-slate-900/40",
  ]}
>
  <!-- 본문과 같은 폭(최대 1024px)으로 가운데 정렬 -->
  <div class="container-cv">
    <!-- client:visible: 이 섹션이 화면에 보이기 시작할 때 애니메이션 JS를 로드·실행 -->
    <Reveal client:visible>
      {
        /* eyebrow가 전달됐을 때만 라벨을 렌더링 (&& 조건부 렌더링) */
        eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-widest text-mint-700 dark:text-mint-400">
            {eyebrow}
          </p>
        )
      }
      <!-- 섹션 제목. sm:text-4xl = 작은 화면 이상에서 글자 크기 확대 -->
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {title}
      </h2>
      <!-- 각 섹션의 실제 내용이 꽂히는 구멍. 사용처: <Section ...>여기 내용</Section> -->
      <div class="mt-10">
        <slot />
      </div>
    </Reveal>
  </div>
</section>
