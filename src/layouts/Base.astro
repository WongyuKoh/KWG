---
// ============================================================
// Base 레이아웃 — 모든 페이지가 공유하는 HTML 뼈대
// ============================================================
// <html>, <head>, <body>를 만드는 유일한 곳입니다.
// 페이지(src/pages/*)는 이 레이아웃으로 감싸서 <slot /> 자리에
// 자기 내용을 끼워 넣습니다. 즉:
//   페이지 → <Base ...> 내용 </Base> → 완성된 HTML 문서
// 여기서 하는 일: 전역 CSS 로드, 파비콘/메타태그, 다크모드 초기화.
import "../styles/global.css"; // Tailwind + 브랜드 민트 색 정의 (전 페이지 공통)
import type { Lang } from "../i18n/ui";
import { withBase } from "../utils/url"; // GitHub Pages 하위경로(/KWG/) 보정

interface Props {
  lang: Lang; // <html lang="..."> 에 들어감 — 검색엔진/스크린리더용
  title: string; // 브라우저 탭 제목
  description: string; // 검색 결과에 보이는 요약문
}

const { lang, title, description } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- 문자 인코딩을 UTF-8로 선언 — 한글이 깨지지 않게 하는 필수 첫 줄 -->
    <meta charset="utf-8" />
    <!-- 모바일에서 "화면 폭 = 기기 폭"으로 렌더링하라는 지시 — 없으면 폰에서 데스크톱 화면이 축소돼 보임 -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- "Astro v5.x로 만들었다"는 표식 — 기능 없음, 통계/디버깅용 관례 -->
    <meta name="generator" content={Astro.generator} />
    <!-- 브라우저 탭에 표시될 아이콘. withBase()가 "/KWG/favicon.png"로 경로를 완성해 줌 -->
    <link rel="icon" type="image/png" href={withBase("favicon.png")} />
    <!-- 브라우저 탭 제목 + 검색 결과의 제목줄. 값은 페이지(index.astro)가 넘겨줌 -->
    <title>{title}</title>
    <!-- 검색 결과에서 제목 아래 표시되는 요약문 (SEO) -->
    <meta name="description" content={description} />

    <!-- Open Graph: 카톡·슬랙 등에 링크를 붙여넣었을 때 나오는 "미리보기 카드"의 정보 -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!--
      다크모드 초기화 스크립트 (FOUC 방지)
      - FOUC(Flash of Unstyled Content): 페이지가 라이트로 떴다가
        뒤늦게 다크로 바뀌며 "번쩍"이는 현상.
      - 이를 막으려고 본문이 그려지기 전에(head 안, is:inline)
        localStorage의 저장값을 읽어 <html class="dark">를 즉시 결정합니다.
      - 저장값이 없으면 기본 다크. 토글 버튼(ThemeToggle.tsx)이
        theme 값을 "dark"/"light"로 저장합니다.
    -->
    <script is:inline> 
		// 원래 화면에 나타낼 때 단계별로 차례로 나타내다보니 처음에 흰색 화면 -> 검은색 화면으로 깜빡이는 문제가 있음.
		// 그래서 inline 을 설정하는데, inline 은 실시간으로 화면을 그리는게 아니라 다 그리고 화면에 나타내는 기능. => 화면 깜빡임이 없어짐.

      // (보충 정정) is:inline의 방향은 위 설명과 반대입니다:
      //   "다 그리고 나서 나타내는" 게 아니라 "그리기 전에 즉시 실행"입니다.
      //   Astro는 원래 일반 <script>를 별도 파일로 모아 화면을 다 그린 뒤 실행하는데
      //   (그래서 흰 화면이 먼저 보임 → 깜빡임), is:inline은 그 최적화를 꺼서
      //   코드를 이 자리에 그대로 박고 <head>를 읽는 즉시 실행시킵니다.
      //   → body가 그려지기 "전에" dark 클래스가 이미 붙어 있어 깜빡임이 없는 것.

      (() => { // 즉시실행함수(IIFE): 이름 없는 함수를 정의하자마자 1회 실행 — 전역 변수를 남기지 않음
        try { // localStorage는 시크릿 모드/보안 설정에서 접근이 차단될 수 있어 try로 감쌈
          // 지난 방문 때 토글 버튼이 저장해 둔 값. "dark" | "light" | null(첫 방문) 중 하나
          const stored = localStorage.getItem("theme");
          // 저장값이 있으면 그것을 따르고("dark"인지 비교해 true/false), 없으면 기본값 다크(true)
          const dark = stored ? stored === "dark" : true;
          // documentElement = <html> 태그. toggle(클래스명, 조건): 조건이 true면 붙이고 false면 뗌
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {} // 실패해도 조용히 무시 — 테마가 기본값이 될 뿐 페이지는 정상 동작
      })(); // ← 마지막 ()가 "지금 바로 호출"
    </script>
  </head>
  <body>
    <slot /> 
	<!-- 
	 Base 를 호출한 파일에서 Base 안에 넣은 요소가 여기에 들어감. 
	 slot 에 이름을 설정해두면, 해당 이름으로 설정한 요소가 여기에 들어가는 형태. 
	 만약 slot 을 <slot> </slot> 형태로 영역을 만든다면, 해당 영역 안에 있는 값은 slot 으로 값이 들어오지 않았을 때 나타나는 기본값 같은 거
	-->
  </body>
</html>
