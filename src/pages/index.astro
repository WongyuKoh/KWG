---
// ============================================================
// 한국어 메인 페이지 — 사이트 루트("/") 담당
// ============================================================
// Astro는 src/pages/ 안의 파일 경로가 곧 URL이 됩니다(파일 기반 라우팅).
//   src/pages/index.astro     → /      (이 파일, 한국어)
//   src/pages/en/index.astro  → /en/   (영어)
// 실제 화면 내용은 PageContent 컴포넌트가 조립하고, 이 파일은
// "어떤 언어로 렌더링할지(lang)"와 <title>·메타 설명만 정합니다.
import Base from "../layouts/Base.astro";
import PageContent from "../components/PageContent.astro";
import { profile } from "../data/profile";

const lang = "ko" as const; // 이 페이지의 언어 — 모든 하위 컴포넌트로 전달됨
const title = `${profile.name[lang]} · ${profile.role[lang]}`; // 브라우저 탭 제목
---

<Base lang={lang} title={title} description={profile.tagline[lang]}>
  <PageContent lang={lang} />
</Base>
